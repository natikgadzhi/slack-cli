# Slack credentials (required for E2E tests)
# Get these from your browser's Slack session.
SLACK_XOXC=
SLACK_XOXD=

# Optional — workspace URL, avoids an extra auth.test API call
SLACK_TEAM_URL=

# Test data — customize for your workspace
SLACK_TEST_CHANNEL=general
SLACK_TEST_MESSAGE_URL=
SLACK_TEST_SEARCH_QUERY=wat
